    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n\n  const data = item.json.body;\n\n  // Creating Date object\n  const data = new Date(data.dateTime);\n\n  // Formatting the date\n  const formattedDate =\n    String(data.getDate()).padStart(2, '0') + '/' +\n    String(data.getMonth() + 1).padStart(2, '0') + '/' +\n    data.getFullYear() + ' ' +\n    String(data.getHours()).padStart(2, '0') + ':' +\n    String(data.getMinutes()).padStart(2, '0') + ':' +\n    String(data.getSeconds()).padStart(2, '0');\n\n  item.json = {\n    title: `${data.name} - Chatbot`,\n    name: data.name,\n    organization: data.organization,\n    email: data.email,\n    cnpj: data.cnpj,\n    phone: data.phone,\n    service: data.service,\n    dateTime: data.dateTime\n  };\n}\n\nreturn $input.all();"
      },
