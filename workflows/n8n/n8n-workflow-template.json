    {
      "parameters": {
        "jsCode": "// User-provided email\nconst userEmail = $('Data Processing').first().json.email.trim().toLowerCase();\n\nfor (const item of $input.all()) {\n  const personEmail = item.json.primary_email?.trim().toLowerCase();\n\n  if (personEmail && personEmail === userEmail) {\n    return [\n      {\n        json: {\n          personId: item.json.id\n        }\n      }\n    ];\n  }\n}\n\n// No match found\nreturn [\n  {\n    json: {\n      personId: null\n    }\n  }\n];"
